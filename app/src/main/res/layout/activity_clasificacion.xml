<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/negro_fondo">

    <!-- TOP BAR -->
    <include
        android:id="@+id/topBar"
        layout="@layout/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- CONTENT -->
    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topBar"
        android:layout_above="@id/bottomBar"
        android:background="@color/negro_fondo">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- TÍTULO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CLASIFICACIÓN"
                android:textSize="22sp"
                android:textColor="@color/blanco"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- SELECTOR DE GRUPO -->
            <include
                android:id="@+id/selector_grupo"
                layout="@layout/item_selector_grupo"
                />

            <!-- CABECERA DE LA TABLA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:background="#1A1A1A"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <TextView
                    android:layout_width="30dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="POS"
                    android:textSize="11sp"
                    android:textColor="@color/gris_texto"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:text="EQUIPO"
                    android:textSize="11sp"
                    android:textColor="@color/gris_texto"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"/>

                <TextView
                    android:layout_width="28dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="PJ"
                    android:textSize="11sp"
                    android:textColor="@color/gris_texto"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="28dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="PG"
                    android:textSize="11sp"
                    android:textColor="@color/gris_texto"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="28dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="PE"
                    android:textSize="11sp"
                    android:textColor="@color/gris_texto"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="28dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="PP"
                    android:textSize="11sp"
                    android:textColor="@color/gris_texto"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="28dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="GF"
                    android:textSize="11sp"
                    android:textColor="@color/gris_texto"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="28dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="GC"
                    android:textSize="11sp"
                    android:textColor="@color/gris_texto"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="28dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="GD"
                    android:textSize="11sp"
                    android:textColor="@color/gris_texto"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="PTS"
                    android:textSize="11sp"
                    android:textColor="@color/blanco"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- CONTENEDOR DINÁMICO DE FILAS -->
            <LinearLayout
                android:id="@+id/contenedorClasificacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

            <!-- LEYENDA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:padding="12dp"
                android:background="#1A1A1A">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="#2196F3"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Promoción de ascenso"
                        android:textSize="12sp"
                        android:textColor="@color/gris_texto"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="#F44336"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Descenso"
                        android:textSize="12sp"
                        android:textColor="@color/gris_texto"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAV -->
    <include
        android:id="@+id/bottomBar"
        layout="@layout/bottom_bar"/>

    <!-- Menus y overlay -->
    <include
        layout="@layout/overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <include
        layout="@layout/menu_menu"
        android:layout_width="280dp"
        android:layout_height="match_parent"/>

    <include
        layout="@layout/menu_user"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_alignParentEnd="true"/>

</RelativeLayout>
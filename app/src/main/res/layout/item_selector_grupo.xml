<?xml version="1.0" encoding="utf-8"?>
<HorizontalScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:scrollbars="none"
    android:padding="4dp"
    android:layout_marginBottom="16dp">

    <LinearLayout
        android:id="@+id/contenedorGrupos"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#1A1A1A"
        android:padding="4dp">

        <TextView
            android:id="@+id/btnGrupo1"
            android:layout_width="72dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="GRUPO 1"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/negro"
            android:background="@drawable/bg_tab_selected"/>

        <TextView
            android:id="@+id/btnGrupo2"
            android:layout_width="72dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="GRUPO 2"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/gris_texto"
            android:background="@android:color/transparent"/>

        <TextView
            android:id="@+id/btnGrupo3"
            android:layout_width="72dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="GRUPO 3"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/gris_texto"
            android:background="@android:color/transparent"/>

        <TextView
            android:id="@+id/btnGrupo4"
            android:layout_width="72dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="GRUPO 4"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/gris_texto"
            android:background="@android:color/transparent"/>

        <TextView
            android:id="@+id/btnGrupo5"
            android:layout_width="72dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="GRUPO 5"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/gris_texto"
            android:background="@android:color/transparent"/>

    </LinearLayout>
</HorizontalScrollView>
<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/negro_fondo">

    <!-- TOP BAR -->
    <include
        android:id="@+id/topBar"
        layout="@layout/top_bar"/>

    <!-- HEADER DE JUEGO -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_below="@id/topBar"
        android:background="@color/negro_secciones"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <!-- Equipo 1 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:background="#555"
                    android:src="@android:drawable/ic_menu_gallery" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Equipo 1"
                    android:textColor="@android:color/white"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Marcador -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:paddingHorizontal="12dp"
                android:text="21:00"
                android:textColor="@android:color/white"
                android:textSize="32sp"
                android:textStyle="bold" />

            <!-- Equipo 2 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:background="#555"
                    android:src="@android:drawable/ic_menu_gallery" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Equipo 2"
                    android:textColor="@android:color/white"
                    android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- CONTENEDOR TABS + SELECTOR -->
    <LinearLayout
        android:id="@+id/contenedorTabsSelector"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header"
        android:orientation="vertical"
        android:background="@color/negro_fondo">

        <!-- TABS -->
        <HorizontalScrollView
            android:id="@+id/tabsPartido"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:scrollbars="none"
            android:padding="4dp">

            <LinearLayout
                android:id="@+id/contenedorTabs"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1A1A1A"
                android:padding="4dp"
                android:layout_gravity="center">

                <TextView
                    android:id="@+id/tabAlineacion"
                    android:layout_width="120dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="ALINEACIÓN"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/negro"
                    android:background="@drawable/bg_tab_selected"/>

                <TextView
                    android:id="@+id/tabEventos"
                    android:layout_width="120dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="EVENTOS"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/gris_texto"
                    android:background="@android:color/transparent"/>

            </LinearLayout>

        </HorizontalScrollView>

        <!-- SELECTOR EQUIPOS -->
        <LinearLayout
            android:id="@+id/selectorEquipos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="10dp">

            <Button
                android:id="@+id/btnEquipo1"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:text="Equipo 1"
                android:textAllCaps="false"
                android:background="@drawable/borde"
                android:textColor="@android:color/white"/>

            <Button
                android:id="@+id/btnEquipo2"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Equipo 2"
                android:textAllCaps="false"
                android:background="@drawable/borde"
                android:backgroundTint="@color/gris_texto"
                android:textColor="@android:color/white"/>
        </LinearLayout>

    </LinearLayout>

    <!-- SCROLLVIEW DE JUGADORES -->
    <ScrollView
        android:id="@+id/scrollAlineacion"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/contenedorTabsSelector"
        android:layout_marginBottom="85dp"
        android:background="@color/negro_fondo"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:id="@+id/listaJugadores"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <include layout="@layout/item_jugador"/>
                <include layout="@layout/item_jugador"/>
                <include layout="@layout/item_jugador"/>
                <include layout="@layout/item_jugador"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- SCROLLVIEW DE EVENTOS -->
    <ScrollView
        android:id="@+id/scrollEventos"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/contenedorTabsSelector"
        android:layout_marginBottom="85dp"
        android:background="@color/negro_fondo"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/listaEventos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"/>

    </ScrollView>

    <!-- BOTTOM NAV -->
    <include
        android:id="@+id/bottomBar"
        layout="@layout/bottom_bar"/>

    <!-- Menus y overlay -->
    <include
        layout="@layout/overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <include
        layout="@layout/menu_menu"
        android:layout_width="280dp"
        android:layout_height="match_parent"/>

    <include
        layout="@layout/menu_user"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_alignParentEnd="true"/>

</RelativeLayout>
